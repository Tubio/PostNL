{
  "name": "postnl",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "lambdas/*"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "upload:resolvers": "aws s3 sync appsync/ s3://postnl-dks-case-${STACK_NAME}-artifacts/appsync/",
    "deploy": "npm run upload:resolvers && sam build && sam deploy",
    "deploy:guided": "npm run upload:resolvers && sam build && sam deploy --guided"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3",
    "@aws-sdk/util-dynamodb": "^3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8",
    "@types/jest": "^29",
    "@types/node": "^20",
    "aws-sdk-client-mock": "^4",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5",
    "esbuild": "^0.25.0"
  }
}
